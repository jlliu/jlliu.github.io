itle\">{{workTitle}} <i class=\"fas fa-external-link-alt\"></i></h4>\n   \n    </a>\n   \n    <g-link v-else :to=\"'/projects/'+workSlug\">\n      <!-- <g-link v-else :to=\"workSlug\"> -->\n    <div class=\"imageContainer\"  :style=\"backgroundImage\"> </div>\n    <h4 class=\"workTitle\">{{workTitle}}</h4>\n\n    </g-link>\n    <h5 class=\"work-detail\"><i>{{workType}}</i></h5>\n  \n    </div>\n</template>\n\n<page-query>\n\n</page-query>\n\n<script>\nexport default {\n  props: ['workId','workTitle','workSlug', 'coverPhotoPath', 'workType'],\n  computed: {\n    backgroundImage () {\n      return 'background-image: url('+this.coverPhotoPath+');'\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n\n.projectElement{\n  .imageContainer{\n    width:100%;\n    height:180px;\n    background-position:center;\n    background-size:cover;\n  }\n  .workTitle{\n    color: $dark-color;\n    padding-bottom:0px;\n    margin-top:16px;\n    margin-bottom:8px;\n    transition:.3s all;\n    .fas {\n      font-size:15px;\n      bottom:1px;\n      position:relative;\n    }\n  }\n\n  .work-detail{\n    margin:0px;\n  }\n\n}\n\n  .projectElement:hover{\n    .workTitle {\n      color:$magenta;\n    }\n    \n  }\n\n\n\n/** CSS for project page**/\n#projectContainer{\n  .grid-container{\n    margin:28px 0px;\n  }\n  .projectElement{\n      display:inline;\n    a{\n      position:relative;\n    }\n    text-align:center;\n    position:relative;\n\n    .img-container{\n      background-image: url('');\n      background-size:cover;\n      background-position:center;\n      max-width: 100%;\n      height:260px;\n        margin:auto;\n        transition:.3s all;\n        position:relative;\n\n    }\n    .img-container:hover{\n      cursor:pointer;\n      \n    }\n    .title{\n      \n        position:absolute;\n        z-index:4;\n        background-color:rgba(0,0,0,0);\n        transition:.2s all;\n        width:100%;\n        height:100%;\n        top:0px;\n        left:0px;\n        display:table;\n        \n        color:rgba(0,0,0,0);\n        \n\n        \n        .overlay{\n          /*margin-top:20px;*/\n        font-weight: bold;\n          font-family: \"Space Mono\";\n          font-size:22px;\n          display: table-cell; \n          vertical-align: middle; \n          text-align: center; \n          .title-text{\n            padding:30px;\n          }\n\n        }\n    }\n\n    .title:hover{\n      background-color:rgba(200,0,200,.6);\n      color:white;\n    }\n\n  }\n\n  @media screen and (max-width: 1000px) {\n    .img-container{\n      .title .overlay{\n        font-size:18px;\n      }\n    }\n  }\n  @media screen and (max-width: 800px) {\n    .img-container{\n      height:300px;\n      max-width:400px;\n    }\n  }\n\n}\n\n</style>\n\n"],"sourceRoot":"src/components"}]}