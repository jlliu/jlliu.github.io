{"remainingRequest":"/Users/jackie/Google Drive/code-dump/my-gridsome-site/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/jackie/Google Drive/code-dump/my-gridsome-site/src/pages/Index.vue?vue&type=style&index=0&lang=css&","dependencies":[{"path":"/Users/jackie/Google Drive/code-dump/my-gridsome-site/src/pages/Index.vue","mtime":1558841224391},{"path":"/Users/jackie/Google Drive/code-dump/my-gridsome-site/node_modules/css-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/jackie/Google Drive/code-dump/my-gridsome-site/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":499162500000},{"path":"/Users/jackie/Google Drive/code-dump/my-gridsome-site/node_modules/postcss-loader/src/index.js","mtime":499162500000},{"path":"/Users/jackie/Google Drive/code-dump/my-gridsome-site/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/jackie/Google Drive/code-dump/my-gridsome-site/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":["\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n/**CRT text animation*/*/\n\n.text, .text >* {\n  position: absolute;\n  top:60px;\n  left:50%;\n  transform:translate(-50%,-50%);\n}\n.text {\n  >* {\n     font-size:80px;\n     font-weight:bold;\n     animation: giggle 1.6s ease infinite;\n     mix-blend-mode: difference;\n     \n  }\n  .r {\n     color:#db00ff;\n     color: $magenta;\n     left:-0.5px;\n\n  }\n  .g {\n     color:#ecff00;\n     color: $yellow;\n     animation-delay:-0.67s;\n  }\n  .b {\n     color:#00f0ff;\n     color: $cyan;\n     animation-delay:-0.33s;\n     left:0.5px;\n  }\n\n}\n\n\n.text-wrapper{\n  /*overflow:hidden;*/\n  height:180px;\n}\n\n @keyframes giggle {\n   0%, 100% {\n      transform:translate(-50%,-50%) translateY(-3px);\n   }\n   50% {\n      transform:translate(-50%,-50%) translateY(3px);\n   }\n}\n\n @keyframes giggleB {\n   0%, 100% {\n      transform:translate(-50%,-50%) translateY(-6px);\n   }\n   50% {\n      transform:translate(-50%,-50%) translateY(6px);\n   }\n}\n@keyframes lines {\n   0% {\n      background-position:0px 0px;\n   }\n   100% {\n      background-position:0px 25px;\n   }\n}\n\n\n.bg-container{\n\n\n  width:100vw;\n  /*height:calc(100vh + 800px);*/\n  position:absolute;\n  left:0px;\n  top:0px;\n  height:1400px;\n  overflow-x:hidden;\n  z-index:-100;\n\n\n  .fas, .far{\n    position:absolute;\n    mix-blend-mode:darken;\n    /*opacity:.5;*/\n     animation:  giggle 1.6s ease infinite;\n     z-index:-100;\n  }\n\n  .magenta{\n    color:$magenta;\n  }\n  .yellow{\n    color:$yellow;\n  }\n  .cyan{\n    color:$cyan;\n  }\n  .x-small{\n    font-size:14px;\n  }\n  .small{\n    font-size:20px;\n  }\n  .med{\n    font-size:60px;\n  }\n  .large{\n    font-size:100px;\n  }\n\n  .x-large{\n    font-size:180px;\n  }\n\n}\n\n.bg-symbol{\n  position:relative;\n  z-index:-100;\n\n  i {\n    position:absolute;\n    top:0px;\n    left:0px;\n    font-size:300px;\n     mix-blend-mode: difference;\n\n  }\n}\n\n\n.hero-arrow{\n      font-size: 48px;\n      position:relative;\n      top:40px;\n/*      left: calc( 50% - 8px);*/\n     /* left: 50%;\n      right: 50%;*/\n/*      top: 630px;\n      position: absolute;*/\n      opacity:0;\n      transition: .6s opacity;\n}\n\n",{"version":3,"sources":["Index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAkNA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;;;AAGA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;;AAGA;;;AAGA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;;AAGA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;;AAGA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Index.vue","sourceRoot":"src/pages","sourcesContent":["<template>\n  <Layout>\n\n    <div class=\"bg-container\">\n    </div>\n\n    <section class=\"hero\">\n      <div class=\"text-wrapper\">\n        <div class=\"text\">\n           <div class=\"r\">jackie&nbsp;liu</div>\n           <div class=\"g\">jackie&nbsp;liu</div>\n           <div class=\"b\">jackie&nbsp;liu</div>\n        </div>\n      </div>\n    \n\n\n      <!-- <img class=\"room\" src=\"room.png\"> -->\n      <h2 class=\"hero-text scroll-reveal\" v-scroll-reveal><i>is an interdisciplinary-at-heart designer, artist, and programmer based in new york city</i></h2>\n        <MainHeader />\n\n          <a class=\"hero-arrow\" href=\"#aboutSection\" id=\"about\">\n            <!-- <font-awesome-icon :icon=\"['fas', 'angle-double-down']\"/> -->\n            <i class=\"fas fa-angle-double-down\"></i>\n          </a>\n    </section>\n\n    <section id=\"about\">\n\n      <div class=\"grid-container\">\n        <div class=\"three-fourth\">\n        <p class=\"scroll-reveal\">\n        hello there, my name is jackie liu! i graduated in 2018 with a B.S. in computer science at MIT. currently, i'm pursuing a master's in creative technology at NYU's <a target=\"_blank\" href=\"https://itp.nyu.edu/\">Interactive Telecommunications Program</a> and working as a design intern at  <a target=\"_blank\" href=\"https://codecademy.com/\">Codecademy</a>. previously, i've done work with <a target=\"_blank\" href=\"https://formlabs.com/\">Formlabs</a> and <a target=\"_blank\" href=\"https://girlswhocode.com/\">Girls Who Code</a>.</p>\n        <p class=\"scroll-reveal\">\n        as a <a href=#workSection>designer</a>, i'm dedicated to crafting effective, critical, and empowering solutions, and specialize in prototyping fluidly between design and code.</p>\n        <!-- <boundary id=\"about\"></boundary> -->\n        <p class=\"scroll-reveal\">\n        as an <a href=#artSection>artist/storyteller</a>, i like to deconstruct the visual language of digital media, then telling honest narratives and advocating for a culture of radical vulnerability and strength in softness.</p>\n        <p class=\"scroll-reveal\">\n        i'm constantly exploring what kinds of things i want to create and how i want to exist. <a href=\"#contactSection\">send me a message</a> if you'd like to collaborate!</p>\n        <!-- <boundary id=\"about\"></boundary><br> -->\n        <a target=\"_blank\" href=\"resume.pdf\" class=\"link-with-arrow\">check out my resume &nbsp; &nbsp;<i class=\"fas fa-long-arrow-alt-right\"></i></a>\n        </div>\n      </div>\n   </section>\n\n\n\n\n  </Layout>\n</template>\n\n<script>\nimport MainHeader from '~/components/MainHeader.vue'\n\n\nexport default {\n  components:{\n      MainHeader\n  },\n  metaInfo: {\n    title: 'Hello, world!'\n  }\n}\n$(document).ready(function(){\n$(\".bg-container\").hide();\n  var width = $(window).width();\n  var num_copies = width*.06 ;\n\n  //Generate 20 random hearts in bg-container\n  var listOfIcons = [];\n  var icons = ['fas fa-heart','far fa-angry','far fa-meh','fas fa-moon','fas fa-angle-down','fas fa-star','fas fa-spa','fas fa-poo','fas fa-dollar-sign']\n  var icons = ['fas fa-heart','fas fa-star', 'fas fa-circle']\n  var icon = icons[Math.floor((Math.random() * (icons.length)) + 0)];\n  for (var i = 0; i < num_copies; i++){\n\n    var width = $(window).width();\n    // console.log(width);\n    var height = $(window).height();\n    \n    var sizes = ['small', 'med','large', 'x-large' ];\n    var colors = ['magenta','yellow','cyan'];\n    \n    \n\n    //Randomly generate position, color, and size\n    \n    var x_position = Math.floor((Math.random() * (width+200)) + -200);\n    // console.log(x_position);\n    var y_position = Math.floor((Math.random() * (height+600)) + -200);\n    var color = colors[Math.floor((Math.random() * (colors.length)) + 0)];\n    var size = sizes[Math.floor((Math.random() * (sizes.length)) + 0)]; \n    var opacity = (Math.random()*.4-.1);\n    // var opacity = .5;\n\n    var rellax_speed = (-Math.random()*5 );\n    var animation_delay = -Math.random();\n\n    var newIcon = document.createElement('i');\n    $(newIcon).addClass(icon+\" \"+color+\" \"+size);\n    $(newIcon).css(\"top\", y_position+\"px\");\n    $(newIcon).css(\"opacity\",opacity);\n    $(newIcon).css(\"left\",x_position+\"px\");\n    $(newIcon).css(\"animation-delay\",animation_delay+\"s\");\n    // $(newIcon).attr(\"data-rellax-speed\",rellax_speed);\n    // console.log(newIcon);\n    \n\n\n    \n\n    $(\".bg-container\").append(newIcon);\n  }\n\n  $(\".bg-container\").append(listOfIcons);\n  $(\".bg-container\").fadeIn(2000,function(){\n    $('.hero-arrow').css(\"opacity\",\"1\");\n  });\n  \n\n\n\n\n  function isScrolledIntoView(el) {\n        var rect = el.getBoundingClientRect();\n        var elemTop = rect.top;\n        var elemBottom = rect.bottom;\n\n        // Only completely visible elements return true:\n        var isVisible = (elemTop >= 0) && (elemBottom <= window.innerHeight);\n\n        return isVisible;\n    \n      // $(\".powrMarkLink\").css('visibility','hidden');\n    }\n\n    //Runs on scroll and updates which Section to make active in the header\n    var activeHeaderId = null;\n\n    function updateHeader() {\n      $.each($(\".nav ul li a\"), function(index,value){\n        var thisLink = value;\n        var id = $(thisLink).attr(\"id\")\n        // console.log(\"id\"+id);\n        //The top or bottom boundary has just scrolled into view, and its ID is not the active one\n        if ($(\"boundary\"+\"#\"+id)[0] !=null) {\n          if ((isScrolledIntoView($(\"boundary\"+\"#\"+id)[0]) || isScrolledIntoView($(\"boundary\"+\"#\"+id)[1]))  && id != activeHeaderId){\n            // console.log(\"test\");\n            $(\".nav a\").not(\"a#\"+id).removeClass(\"active\");\n            var activeHeaderId = id;\n            $(\"a#\"+id).addClass(\"active\");\n          }\n        }\n\n      });\n\n    };\n\n    \n    console.log(\"poop\");\n\n    // $(\".nav\").sticky({topSpacing:0});\n\n    document.addEventListener(\"scroll\", updateHeader);\n\n    const $navbar = $('.nav');\n\n    $('a[href^=\"#\"]').on('click', function(e) {\n        e.preventDefault();\n        const scrollTop =\n            $($(this).attr('href')).position().top -\n            $navbar.outerHeight();\n\n        $('html, body').animate({ scrollTop });\n        var id = $(this).attr(\"id\")\n        $(\".nav a\").not(\"a#\"+id).removeClass(\"active\");\n      var activeHeaderId = id;\n      $(\"a#\"+id).addClass(\"active\");\n\n    });\n\n\n    $('.hero-arrow').on('click', function(e) {\n      console.log(\"hero clicked\");\n        $(\"#aboutSection\").trigger(\"click\");\n\n    })\n\n    $(\"#contact img, #contact .button\").hover(function(){\n      $(\"#contact img\").addClass('hovered');\n      console.log('hover');\n    }, function(){\n      $(\"#contact img\").removeClass('hovered');\n    });\n\n  var username = \"jackieleeliu\";\n\n  var hostname = \"gmail.com\";\n\n  var linktext = username + \"@\" + hostname ;\n\n  var emailHTML = \"<a class='button' href='mailto:\" +username+\"@\"+hostname+\"'>e-mail me</a>\";\n  $(\".emailWrapper\").html(emailHTML);\n\n})\n\n</script>\n\n<style>\n\n/**CRT text animation*/*/\n\n.text, .text >* {\n  position: absolute;\n  top:60px;\n  left:50%;\n  transform:translate(-50%,-50%);\n}\n.text {\n  >* {\n     font-size:80px;\n     font-weight:bold;\n     animation: giggle 1.6s ease infinite;\n     mix-blend-mode: difference;\n     \n  }\n  .r {\n     color:#db00ff;\n     color: $magenta;\n     left:-0.5px;\n\n  }\n  .g {\n     color:#ecff00;\n     color: $yellow;\n     animation-delay:-0.67s;\n  }\n  .b {\n     color:#00f0ff;\n     color: $cyan;\n     animation-delay:-0.33s;\n     left:0.5px;\n  }\n\n}\n\n\n.text-wrapper{\n  /*overflow:hidden;*/\n  height:180px;\n}\n\n @keyframes giggle {\n   0%, 100% {\n      transform:translate(-50%,-50%) translateY(-3px);\n   }\n   50% {\n      transform:translate(-50%,-50%) translateY(3px);\n   }\n}\n\n @keyframes giggleB {\n   0%, 100% {\n      transform:translate(-50%,-50%) translateY(-6px);\n   }\n   50% {\n      transform:translate(-50%,-50%) translateY(6px);\n   }\n}\n@keyframes lines {\n   0% {\n      background-position:0px 0px;\n   }\n   100% {\n      background-position:0px 25px;\n   }\n}\n\n\n.bg-container{\n\n\n  width:100vw;\n  /*height:calc(100vh + 800px);*/\n  position:absolute;\n  left:0px;\n  top:0px;\n  height:1400px;\n  overflow-x:hidden;\n  z-index:-100;\n\n\n  .fas, .far{\n    position:absolute;\n    mix-blend-mode:darken;\n    /*opacity:.5;*/\n     animation:  giggle 1.6s ease infinite;\n     z-index:-100;\n  }\n\n  .magenta{\n    color:$magenta;\n  }\n  .yellow{\n    color:$yellow;\n  }\n  .cyan{\n    color:$cyan;\n  }\n  .x-small{\n    font-size:14px;\n  }\n  .small{\n    font-size:20px;\n  }\n  .med{\n    font-size:60px;\n  }\n  .large{\n    font-size:100px;\n  }\n\n  .x-large{\n    font-size:180px;\n  }\n\n}\n\n.bg-symbol{\n  position:relative;\n  z-index:-100;\n\n  i {\n    position:absolute;\n    top:0px;\n    left:0px;\n    font-size:300px;\n     mix-blend-mode: difference;\n\n  }\n}\n\n\n.hero-arrow{\n      font-size: 48px;\n      position:relative;\n      top:40px;\n/*      left: calc( 50% - 8px);*/\n     /* left: 50%;\n      right: 50%;*/\n/*      top: 630px;\n      position: absolute;*/\n      opacity:0;\n      transition: .6s opacity;\n}\n\n</style>\n"]}]}