urcesContent":["<template>\n\n   <div class=\"placeholder\">\n   <div class=\"links nav\" id=\"navbar\">\n    <div class=\"nav-wrapper\">\n    <a class=\"nav-name\" href=\"/\">jackie liu</a>\n    <ul class=\"linkList\">  \n      <!-- <li><a href=\"/about\" id=\"aboutLink\"><span>about</span></a></li> -->\n      <li><a href=\"/projects\" id=\"workLink\"><span>projects</span></a></li>\n      <li><a href=\"/blog\" target=\"_blank\" id=\"blog\"><span>blog</span></a></li>\n      <li>\n        <a class=\"email\" target=\"_blank\" href=\"\" .=\"emailLink\"><i class=\"far fa-envelope\"></i></a>\n        <a href=\"https://www.instagram.com/jacq_ilu/\" target=\"_blank\"  > <i class=\"fab fa-instagram\"></i></a>\n      </li>\n\n     \n    </ul>\n    </div>\n  </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'MainHeader',\n  mounted(){\n\n      $(document).ready(function(){\n          window.onscroll = function() {myFunction()};\n\n          var navbar = document.getElementById(\"navbar\");\n          var sticky = navbar.offsetTop;\n\n          function myFunction() {\n            if (window.pageYOffset >= (sticky+600)) {\n              navbar.classList.add(\"is-sticky\")\n            } else {\n              navbar.classList.remove(\"is-sticky\");\n            }\n          }\n\n          $(\".home .nav-name\").click(function(){\n            console.log(\"nav name clicked\");\n            $(window).scrollTop(0);\n          })\n\n\n          } );\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n$navbarHeight: 65px;\n.placeholder{\n  height:90px;\n\n}\n\n.nav{\n  height:$navbarHeight;\n  font-family:'Space Mono', monospace;\n  font-size:14px;\n  font-weight:bold;\n  position:relative;\n  margin:auto;\n  width:100%;\n  left:0px;\n  z-index:9000 !important;\n\n  \n  .nav-wrapper{\n    /*width:85%;*/\n    height:100%;\n    max-width:$max-content-width;\n    margin:auto;\n    position:relative;\n    \n\n    ul{\n      display:inline-block;\n\n      padding:0px;\n      margin:0px;\n\n    }\n    .nav-name{\n      padding-left:0px !important;\n      position:relative;\n      font-size:20px;\n      font-weight:bold;\n      color:black;\n      line-height:65px;\n      /*display:none;*/\n    }\n    ul{\n      list-style-type:none;\n      li{\n      display:inline-block ;\n       line-height:$navbarHeight;\n       \n      }\n      li:not(:last-child){\n        padding:0px 24px;\n      }\n      li.active a {\n        color: black;\n        font-weight:bolder;\n        \n      }\n      a{\n        color:black;\n      }\n      a:not(:last-child){\n\n        padding:0px 16px;\n      }\n\n      a:hover, .nav-name:hover{\n        color:magenta !important;\n      }\n    }\n\n  }\n\n\n}\n\n.nav:not(.is-sticky){\n  .linkList{\n    float:right;\n  }\n}\n.is-sticky.nav{\n  transition:.2s background-color;\n  transition-timing-function: ease;\n  box-shadow: 0px 0px 5px 1px #00000021;\n  background-color:white;\n  left:0 !important;\n  top:0px;\n  position:fixed;\n  .nav-name{\n    display:inline-block;\n    line-height:$navbarHeight;\n\n  }\n  ul{\n    float:right;\n    margin:0px;\n  }\n  .nav-wrapper{\n      text-align:left;\n  }\n  /*width:100vw !important;*/\n\n}\n@media only screen and (max-width: $medium-breakpoint) {\n/*  .nav-wrapper{\n    width: calc( 100% - 32px);\n  }*/\n}\n\n\n@media only screen and (max-width: $small-breakpoint) {\n\n  .nav:not(.singlePage, .project-page){\n    text-align:left;\n    #nav-portfolioPageTitle {\n      display:none !important;\n      /*background-color:blue;*/\n    }\n    .nav-pagination{\n\n      position: absolute;\n        bottom: 0px !important;\n        margin-bottom: 0px;\n        right: 0px;\n\n    }\n    .nav-name{\n      \n      /*display:none !important;*/\n      left:0px;\n      padding-left:0px !important;\n    }\n    ul{\n      padding-left:0px;\n      li:not(:last-child){\n        padding:0px 16px 0px 0px !important;\n      }\n      a{\n        padding:0px;\n      }\n    }\n\n    .nav-wrapper{\n      /*width:100%;*/\n      text-align:center;\n    }\n  }\n  .nav.singlePage{\n    .nav-wrapper {\n      white-space:nowrap;\n      overflow:hidden;\n      height:65px;\n      /*width:800px;*/\n    }\n  }\n.is-sticky.nav{\n    .nav-wrapper{\n      text-align:left;\n      width: calc( 100% - 32px);\n    }\n    ul{\n      float:none;\n      padding:0px;\n    }\n  }\n  .home {\n    .nav:not(.is-sticky) {\n      .nav-name{\n      display:none !important;\n      }\n      .nav-wrapper{\n        width:100%;\n      }\n        ul{\n          padding-left: 0px !important;\n        }\n    }\n    .is-sticky.nav{\n      .nav-name{\n        display:block !important;\n      }\n      ul{\n        display: none !important;\n        \n      }\n    }\n  }\n\n\n  \n   \n}\n</style>"]}]}