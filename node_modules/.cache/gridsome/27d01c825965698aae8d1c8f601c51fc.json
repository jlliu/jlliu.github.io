ve;\n\n    }\n    .img-container:hover{\n      cursor:pointer;\n      \n    }\n    .title{\n      \n        position:absolute;\n        z-index:4;\n        background-color:rgba(0,0,0,0);\n        transition:.2s all;\n        width:100%;\n        height:100%;\n        top:0px;\n        left:0px;\n        display:table;\n        \n        color:rgba(0,0,0,0);\n        \n\n        \n        .overlay{\n          /*margin-top:20px;*/\n        font-weight: bold;\n          font-family: \"Space Mono\";\n          font-size:22px;\n          display: table-cell; \n          vertical-align: middle; \n          text-align: center; \n          .title-text{\n            padding:30px;\n          }\n\n        }\n    }\n\n    .title:hover{\n      background-color:rgba(200,0,200,.6);\n      color:white;\n    }\n\n  }\n\n  @media screen and (max-width: 1000px) {\n    .img-container{\n      .title .overlay{\n        font-size:18px;\n      }\n    }\n  }\n  @media screen and (max-width: 800px) {\n    .img-container{\n      height:300px;\n      max-width:400px;\n    }\n  }\n\n}\n\n</style>\n\n"]}]}